LEARNING_AI_SERVICE_NAME=synapse-learning-ai
LEARNING_AI_VERSION=0.1.0
LEARNING_AI_ENVIRONMENT=local

# API Keys
LEARNING_AI_ANTHROPIC_API_KEY=<replace-me>
